{
  "manifest_version": 3,
  "name": "Woffuk",
  "version": "3.0",
  "description": "Automatically clock in/out on Woffu at scheduled times",
  "permissions": [
    "alarms",
    "storage",
    "cookies",
    "notifications",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.woffu.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Woffuk"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
